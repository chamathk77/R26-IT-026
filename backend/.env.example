PORT=3000
NODE_ENV=development

# Encode @ in password as %40. Include a DB name (e.g. /smartcost) so MongoDB
# does not default to the "test" database.
MONGODB_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/smartcost?authSource=admin&replicaSet=your-replica-set&tls=true&retryWrites=true&w=majority&appName=SmartCost

# Required for JWT (use a long random string in production)
JWT_SECRET=
